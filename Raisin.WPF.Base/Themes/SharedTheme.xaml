<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:controls="clr-namespace:Raisin.WPF.Base.Controls">

    <ResourceDictionary.MergedDictionaries>
        <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="BlueGrey" SecondaryColor="Teal" />
        <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Shared toolbar icon button: transparent, rounded hover highlight,
         active=full opacity + primary tint, inactive=dimmed -->
    <ControlTemplate x:Key="ToolbarIconButtonTemplate" TargetType="ButtonBase">
        <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                              TextElement.Foreground="{TemplateBinding Foreground}"/>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="White" Opacity="0.08"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="ToolbarIconToggleButton" TargetType="ToggleButton">
        <Setter Property="Template" Value="{StaticResource ToolbarIconButtonTemplate}"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Foreground" Value="#888"/>
        <Setter Property="Opacity" Value="0.4"/>
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="#CCCCCC"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ToolbarIconButton" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource ToolbarIconButtonTemplate}"/>
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
    </Style>

    <!-- Compact MD raised button: sleek with ripple + shadow -->
    <Style x:Key="CompactButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Padding" Value="12,2" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="2"/>
            </Setter.Value>
        </Setter>
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
        <Setter Property="Opacity" Value="0.85" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="1.0" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Compact DataGrid rows -->
    <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
        <Setter Property="RowHeight" Value="22"/>
    </Style>
    <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
        <Setter Property="Padding" Value="4,1"/>
    </Style>
    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Compact filter ComboBox: MD underline focus animation, dark background, menu-like item spacing -->
    <Style x:Key="FilterComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="Height" Value="22"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="Padding" Value="6,2,6,2"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="MinHeight" Value="0"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Padding="6,6,8,6"
                                        BorderThickness="2,0,0,0" BorderBrush="Transparent"
                                        SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <SolidColorBrush Color="#3E3E42" Opacity="0"/>
                                    </Border.Background>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Bd"
                                                        Storyboard.TargetProperty="Background.Opacity"
                                                        To="1" Duration="0:0:0.12"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Bd"
                                                        Storyboard.TargetProperty="Background.Opacity"
                                                        To="0" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#007ACC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Multi-select filter dropdown: checkbox list with Shift+Click "select below" -->
    <Style TargetType="{x:Type controls:MultiSelectDropdown}">
        <Setter Property="Height" Value="22"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MultiSelectDropdown}">
                    <Grid>
                        <ToggleButton x:Name="PART_ToggleButton" Focusable="False" Style="{x:Null}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd" Background="{Binding ToggleBackground, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                            BorderBrush="{Binding ToggleBorderBrush, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                            BorderThickness="1" CornerRadius="2" SnapsToDevicePixels="True"
                                            Padding="6,0,20,0">
                                        <TextBlock Text="{Binding SummaryText, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                                   VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding HoverBorderBrush, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{Binding AccentBrush, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Path Data="M0,0 L4,4 8,0" Stroke="{TemplateBinding ChevronBrush}" StrokeThickness="1.5"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Margin="0,0,6,0" IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                               Placement="Bottom" AllowsTransparency="True" StaysOpen="True"
                               Focusable="False" PopupAnimation="None"
                               MinWidth="{Binding ActualWidth, ElementName=PART_ToggleButton}">
                            <Border Background="{Binding PopupBackground, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                    BorderBrush="{Binding PopupBorderBrush, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                    BorderThickness="1" MaxHeight="300" Margin="0,1,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="PART_ItemsList"
                                                  ItemsSource="{TemplateBinding ItemsSource}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="ItemBorder" Background="Transparent"
                                                        Padding="{Binding ItemPadding, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                                                  Focusable="False"/>
                                                        <ContentPresenter Content="{Binding}" Margin="0"
                                                            ContentTemplate="{Binding ItemContentTemplate, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"/>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="Background"
                                                                Value="{Binding ItemHoverBackground, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Subtle variant: darker background, underline hover, animated item hover (matches FilterComboBox) -->
    <Style x:Key="FieldDropdownSubtle" TargetType="{x:Type controls:MultiSelectDropdown}">
        <Setter Property="Height" Value="22"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ToggleBackground" Value="#2D2D30"/>
        <Setter Property="ToggleBorderBrush" Value="#2D2D30"/>
        <Setter Property="HoverBorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        <Setter Property="AccentBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        <Setter Property="PopupBorderBrush" Value="#3F3F46"/>
        <Setter Property="ItemPadding" Value="6,6,8,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MultiSelectDropdown}">
                    <Grid>
                        <ToggleButton x:Name="PART_ToggleButton" Focusable="True" Style="{x:Null}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press" FocusVisualStyle="{x:Null}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{Binding ToggleBackground, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                            SnapsToDevicePixels="True" Padding="6,0,20,0">
                                        <TextBlock Text="{Binding SummaryText, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                                   VerticalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Border BorderThickness="0,0,0,1"
                                BorderBrush="#3F3F46"
                                SnapsToDevicePixels="True" IsHitTestVisible="False"/>
                        <Border x:Name="ActiveUnderline" BorderThickness="0,0,0,2"
                                BorderBrush="{Binding AccentBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                SnapsToDevicePixels="True" IsHitTestVisible="False"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0"/>
                            </Border.RenderTransform>
                        </Border>
                        <Path Data="M0,0 L4,4 8,0" Stroke="{TemplateBinding ChevronBrush}" StrokeThickness="1.5"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Margin="0,0,6,0" IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                               Placement="Bottom" AllowsTransparency="True" StaysOpen="True"
                               Focusable="False" PopupAnimation="None"
                               MinWidth="{Binding ActualWidth, ElementName=PART_ToggleButton}">
                            <Grid MaxHeight="300" Margin="6,0,6,6">
                                <Border BorderBrush="{DynamicResource MaterialDesignShadowBrush}"
                                        BorderThickness="1" CornerRadius="0,0,4,4">
                                    <Border.Effect>
                                        <BlurEffect Radius="6"/>
                                    </Border.Effect>
                                </Border>
                                <Border Background="{Binding PopupBackground, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"
                                        BorderThickness="0" CornerRadius="0,0,4,4"
                                        Margin="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="PART_ItemsList"
                                                  ItemsSource="{TemplateBinding ItemsSource}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="ItemBorder"
                                                        Padding="{Binding ItemPadding, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#3E3E42" Opacity="0"/>
                                                    </Border.Background>
                                                    <StackPanel Orientation="Horizontal">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                                                  Focusable="False"/>
                                                        <ContentPresenter Content="{Binding}" Margin="0"
                                                            ContentTemplate="{Binding ItemContentTemplate, RelativeSource={RelativeSource AncestorType={x:Type controls:MultiSelectDropdown}}}"/>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemBorder"
                                                                        Storyboard.TargetProperty="Background.Opacity"
                                                                        To="1" Duration="0:0:0.12"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ItemBorder"
                                                                        Storyboard.TargetProperty="Background.Opacity"
                                                                        To="0" Duration="0:0:0.3"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="HoverIn">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveUnderline"
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="HoverIn"/>
                                <BeginStoryboard x:Name="HoverOut">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveUnderline"
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Trigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="HoverOut"/>
                                <BeginStoryboard x:Name="FocusIn">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveUnderline"
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="FocusIn"/>
                                <BeginStoryboard x:Name="FocusOut">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveUnderline"
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsDropDownOpen, RelativeSource={RelativeSource Self}}" Value="True">
                            <DataTrigger.EnterActions>
                                <StopStoryboard BeginStoryboardName="FocusOut"/>
                                <StopStoryboard BeginStoryboardName="HoverOut"/>
                                <BeginStoryboard x:Name="OpenIn">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveUnderline"
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="1" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="OpenIn"/>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ActiveUnderline"
                                            Storyboard.TargetProperty="RenderTransform.ScaleX"
                                            To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ Dark form controls ═══ -->

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#888888"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Margin" Value="0,0,0,3"/>
    </Style>

    <Style x:Key="FieldBox" TargetType="TextBox">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="#CCCCCC"/>
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="#569DE5"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FieldCombo" TargetType="controls:FieldComboBox">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="Foreground" Value="#CCCCCC"/>
        <Setter Property="BorderBrush" Value="#3F3F46"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Padding="6,4" SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <SolidColorBrush Color="#3E3E42" Opacity="0"/>
                                    </Border.Background>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Bd"
                                                        Storyboard.TargetProperty="Background.Opacity"
                                                        To="1" Duration="0:0:0.12"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="Bd"
                                                        Storyboard.TargetProperty="Background.Opacity"
                                                        To="0" Duration="0:0:0.3"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:FieldComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <ToggleButton Focusable="False" Style="{x:Null}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd"
                                            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            Padding="{Binding Padding, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter IsHitTestVisible="False"
                                                          Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                          ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                          ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                          VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#7EB4EA"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsDropDownOpen, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#569DE5"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ComboBox}}" Value="True">
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#569DE5"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Path Data="M0,0 L4,4 8,0" Stroke="#999999" StrokeThickness="1.5"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Margin="0,0,8,0" IsHitTestVisible="False"/>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="None"
                               MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                            <Grid x:Name="DropdownBorder" MaxHeight="300" Margin="6,1,6,6"
                                  Opacity="0">
                                <Border BorderBrush="#111111" BorderThickness="1">
                                    <Border.Effect>
                                        <BlurEffect Radius="6"/>
                                    </Border.Effect>
                                </Border>
                                <Border Background="#2D2D30" BorderBrush="#3F3F46"
                                        BorderThickness="1" Margin="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="DropdownBorder"
                                            Storyboard.TargetProperty="Opacity"
                                            From="0" To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="DropdownBorder"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
