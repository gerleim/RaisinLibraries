<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:settings="clr-namespace:Raisin.WPF.Base.Settings"
                    xmlns:behaviors="clr-namespace:Raisin.WPF.Base.Behaviors">

    <BooleanToVisibilityConverter x:Key="SettingsBoolToVis"/>

    <!-- Shared style for the setting row wrapper -->
    <Style x:Key="SettingRowBorder" TargetType="Border">
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="BorderThickness" Value="2,0,0,0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsModified}" Value="True">
                <Setter Property="BorderBrush" Value="Teal"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Compact reset button style — always visible, dimmed when at default -->
    <Style x:Key="SettingsResetButton" TargetType="Button">
        <Setter Property="Content" Value="Reset"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="4,0,0,0"/>
        <Setter Property="Opacity" Value="0.25"/>
        <Setter Property="IsEnabled" Value="False"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsModified}" Value="True">
                <Setter Property="Opacity" Value="1.0"/>
                <Setter Property="IsEnabled" Value="True"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Category Header -->
    <DataTemplate x:Key="SharedCategoryHeaderTemplate" DataType="{x:Type settings:CategoryHeaderItem}">
        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
    </DataTemplate>

    <!-- Bool -->
    <DataTemplate x:Key="SharedBoolTemplate" DataType="{x:Type settings:BoolSettingItem}">
        <Border Style="{StaticResource SettingRowBorder}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource SettingsResetButton}"
                        Command="{Binding ResetCommand}"/>
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding Key}" FontFamily="Consolas" FontSize="10"
                                   Opacity="0.4" VerticalAlignment="Center" Margin="8,0,0,0"
                                   DockPanel.Dock="Right"/>
                        <CheckBox IsChecked="{Binding Value}" Content="{Binding DisplayName}" FontWeight="SemiBold"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.6"
                               FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- Int -->
    <DataTemplate x:Key="SharedIntTemplate" DataType="{x:Type settings:IntSettingItem}">
        <Border Style="{StaticResource SettingRowBorder}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource SettingsResetButton}"
                        Command="{Binding ResetCommand}"/>
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding Key}" FontFamily="Consolas" FontSize="10"
                                   Opacity="0.4" VerticalAlignment="Center" Margin="8,0,0,0"
                                   DockPanel.Dock="Right"/>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.6"
                               FontSize="11" Margin="0,2,0,0"/>
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="80"
                             HorizontalAlignment="Left" Margin="0,4,0,0"
                             behaviors:NumericInputBehavior.Mode="Int"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- Double -->
