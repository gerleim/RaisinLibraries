                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.6"
                               FontSize="11" Margin="0,2,0,0"/>
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="60"
                             HorizontalAlignment="Left" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- Choice (ComboBox) -->
    <DataTemplate x:Key="SharedChoiceTemplate" DataType="{x:Type settings:ChoiceSettingItem}">
