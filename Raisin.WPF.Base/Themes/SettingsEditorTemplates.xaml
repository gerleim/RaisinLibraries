                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.6"
                               FontSize="11" Margin="0,2,0,0"/>
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="160"
                             HorizontalAlignment="Left" Margin="0,4,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- Offset (value + mode combo) -->
    <DataTemplate x:Key="SharedOffsetTemplate" DataType="{x:Type settings:OffsetSettingItem}">
        <Border Style="{StaticResource SettingRowBorder}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource SettingsResetButton}"
                        Command="{Binding ResetCommand}"/>
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding Key}" FontFamily="Consolas" FontSize="10"
                                   Opacity="0.4" VerticalAlignment="Center" Margin="8,0,0,0"
                                   DockPanel.Dock="Right"/>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.6"
                               FontSize="11" Margin="0,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="80"
                                 behaviors:NumericInputBehavior.Mode="Double"/>
                        <ComboBox ItemsSource="{Binding ModeChoices}"
                                  SelectedIndex="{Binding ModeIndex}"
                                  Width="60" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- TimePair (two TimeOnly side by side) -->
    <DataTemplate x:Key="SharedTimePairTemplate" DataType="{x:Type settings:TimePairSettingItem}">
        <Border Style="{StaticResource SettingRowBorder}">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource SettingsResetButton}"
                        Command="{Binding ResetCommand}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <DockPanel>
                            <TextBlock Text="{Binding LeftKey}" FontFamily="Consolas" FontSize="10"
                                       Opacity="0.4" VerticalAlignment="Center" Margin="8,0,0,0"
                                       DockPanel.Dock="Right"/>
                            <TextBlock Text="{Binding LeftDisplayName}" FontWeight="SemiBold"/>
                        </DockPanel>
                        <TextBlock Text="{Binding LeftDescription}" TextWrapping="Wrap" Opacity="0.6"
                                   FontSize="11" Margin="0,2,0,0"/>
                        <TextBox Text="{Binding LeftText, UpdateSourceTrigger=PropertyChanged}" Width="60"
                                 HorizontalAlignment="Left" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <DockPanel>
                            <TextBlock Text="{Binding RightKey}" FontFamily="Consolas" FontSize="10"
                                       Opacity="0.4" VerticalAlignment="Center" Margin="8,0,0,0"
                                       DockPanel.Dock="Right"/>
                            <TextBlock Text="{Binding RightDisplayName}" FontWeight="SemiBold"/>
                        </DockPanel>
                        <TextBlock Text="{Binding RightDescription}" TextWrapping="Wrap" Opacity="0.6"
                                   FontSize="11" Margin="0,2,0,0"/>
                        <TextBox Text="{Binding RightText, UpdateSourceTrigger=PropertyChanged}" Width="60"
                                 HorizontalAlignment="Left" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </DockPanel>
        </Border>
    </DataTemplate>

