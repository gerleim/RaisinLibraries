<Window x:Class="Raisin.StyleInspector.InspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Raisin.StyleInspector"
        Title="Style Inspector"
        Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        Background="#FF1E1E1E"
        Foreground="#FFCCCCCC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Shared item container style for inspect mode -->
        <Style x:Key="InspectorItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF264F78"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A2D2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                    <Setter Property="Opacity" Value="0.45"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Compare mode item container -->
        <Style x:Key="CompareItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF264F78"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A2D2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMatch}" Value="True">
                    <Setter Property="Opacity" Value="0.45"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Inspect mode template -->
        <DataTemplate x:Key="InspectTemplate" DataType="{x:Type local:InspectedProperty}">
            <Grid>
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Setter" Click="OnCopySetterClick"/>
                        <MenuItem Header="Copy Value" Click="OnCopyValueClick"/>
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="PropName" MinWidth="150"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Source" MinWidth="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Name}"
                           Foreground="#FFCCCCCC" Margin="0,0,12,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0" MinWidth="24"
                            VerticalAlignment="Center" ToolTip="{Binding OriginDetail}">
                    <TextBlock Text="{Binding SourceTag}"
                               Foreground="{Binding SourceBrush}"
                               FontWeight="Bold"
                               ToolTip="{Binding SourceTooltip}"/>
                    <TextBlock Text="{Binding StyleOrigin}" Foreground="#FF666666" FontSize="10"
                               Margin="4,0,0,0" MaxWidth="150" TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StyleOrigin}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Value editors -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Color swatch -->
                    <Border Width="12" Height="12" Margin="0,0,4,0" CornerRadius="2"
                            Background="{Binding ColorPreview}"
                            BorderBrush="#FF555555" BorderThickness="1"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ColorPreview}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Bool editor -->
                    <CheckBox IsChecked="{Binding BoolValue, Mode=OneWay}"
                              Checked="OnBoolChanged" Unchecked="OnBoolChanged"
                              VerticalAlignment="Center">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBoolType}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Enum editor -->
                    <ComboBox ItemsSource="{Binding EnumValues}"
                              SelectedItem="{Binding Value, Mode=OneWay}"
                              SelectionChanged="OnEnumChanged"
                              Background="#FF3E3E42" Foreground="#FFCCCCCC"
                              BorderBrush="#FF555555" MinWidth="100"
                              Padding="2,0" FontSize="12">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnumType}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <!-- Text editor -->
                    <TextBox Text="{Binding DisplayValue, Mode=OneWay}"
                             KeyDown="OnValueKeyDown" LostFocus="OnValueLostFocus"
                             Background="Transparent" Foreground="#FFAAAAAA"
                             BorderThickness="0" Padding="0"
                             MinWidth="100" FontSize="12"
                             VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTextType}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                                <Style.Resources>
                                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF264F78"/>
                                </Style.Resources>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                <!-- Reset button -->
                <Button Grid.Column="3" Content="×" Click="OnResetClick"
                        Padding="4,0" Margin="4,0,0,0" FontSize="12"
                        Foreground="#FF888888" Background="Transparent"
                        BorderThickness="0" VerticalAlignment="Center"
                        ToolTip="Reset to original value">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEdited}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Compact TreeViewItem style shared by both trees -->
        <Style x:Key="CompactTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#FFD4D4D4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <Border x:Name="Bd" Background="Transparent" Padding="1,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press" Background="Transparent" BorderThickness="0"
                                                  Width="12" Padding="0">
                                        <TextBlock Text="▸" Foreground="#FF888888" FontSize="10"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="True">
                                                            <Setter Property="Text" Value="▾"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter x:Name="ItemsHost" Margin="10,0,0,0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF264F78"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#FF2A2D2E"/>
                            </MultiTrigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compare mode template -->
        <DataTemplate x:Key="CompareTemplate" DataType="{x:Type local:ComparedProperty}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="PropName" MinWidth="140"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="SrcA" MinWidth="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto" MinWidth="1"/>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="SrcB" MinWidth="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Name}"
                           Foreground="#FFCCCCCC" Margin="0,0,8,0"
                           VerticalAlignment="Center"/>

                <!-- Value A -->
                <TextBlock Grid.Column="1" Text="{Binding SourceTagA}"
                           Foreground="{Binding SourceBrushA}"
                           FontWeight="Bold" Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           ToolTip="{Binding SourceTooltipA}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10" Height="10" Margin="0,0,3,0" CornerRadius="2"
                            Background="{Binding ColorPreviewA}"
                            BorderBrush="#FF555555" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ColorPreviewA}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock Text="{Binding DisplayValueA}" Foreground="#FFAAAAAA" FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Separator -->
                <Border Grid.Column="3" Width="1" Background="#FF3F3F46" Margin="6,0"/>

                <!-- Value B -->
                <TextBlock Grid.Column="4" Text="{Binding SourceTagB}"
                           Foreground="{Binding SourceBrushB}"
                           FontWeight="Bold" Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           ToolTip="{Binding SourceTooltipB}"/>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="10" Height="10" Margin="0,0,3,0" CornerRadius="2"
                            Background="{Binding ColorPreviewB}"
                            BorderBrush="#FF555555" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ColorPreviewB}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock Foreground="#FFAAAAAA" FontSize="12"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding DisplayValueB}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMatch}" Value="True">
                                        <Setter Property="Text" Value="="/>
                                        <Setter Property="Foreground" Value="#FF666666"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1" Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PickButton" Click="OnPickClick"
                        Padding="4,3" Margin="0,0,4,0" ToolTip="Pick element (A)"
                        Foreground="#FFCCCCCC" Background="#FF3E3E42" BorderBrush="#FF555555">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="16" Height="16">
                                <Ellipse Canvas.Left="3" Canvas.Top="3" Width="10" Height="10"
                                         Stroke="#FFCCCCCC" StrokeThickness="1.4" Fill="Transparent"/>
                                <Line X1="8" Y1="0" X2="8" Y2="4" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                                <Line X1="8" Y1="12" X2="8" Y2="16" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                                <Line X1="0" Y1="8" X2="4" Y2="8" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                                <Line X1="12" Y1="8" X2="16" Y2="8" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="A" Foreground="#FF9CDCFE" FontWeight="Bold" FontSize="10"
                                   Margin="2,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="PickBButton" Click="OnPickBClick"
                        Padding="4,3" Margin="0,0,8,0" ToolTip="Pick element (B) for comparison"
                        Foreground="#FFCCCCCC" Background="#FF3E3E42" BorderBrush="#FF555555">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="18" Height="18">
                            <Canvas Width="16" Height="16">
                                <Ellipse Canvas.Left="3" Canvas.Top="3" Width="10" Height="10"
                                         Stroke="#FFCCCCCC" StrokeThickness="1.4" Fill="Transparent"/>
                                <Line X1="8" Y1="0" X2="8" Y2="4" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                                <Line X1="8" Y1="12" X2="8" Y2="16" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                                <Line X1="0" Y1="8" X2="4" Y2="8" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                                <Line X1="12" Y1="8" X2="16" Y2="8" Stroke="#FFCCCCCC" StrokeThickness="1.4"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="B" Foreground="#FFCE9178" FontWeight="Bold" FontSize="10"
                                   Margin="2,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBox x:Name="SearchBox" Width="160"
                         Background="#FF3E3E42" Foreground="#FFCCCCCC" BorderBrush="#FF555555"
                         Padding="4,2" VerticalContentAlignment="Center"
                         TextChanged="OnSearchChanged"/>
                <CheckBox x:Name="HideDefaultsBox" Content="Hide defaults"
                          Foreground="#FFAAAAAA" Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          Checked="OnFilterChanged" Unchecked="OnFilterChanged"/>
                <CheckBox x:Name="DiffsOnlyBox" Content="Diffs only"
                          Foreground="#FFAAAAAA" Margin="12,0,0,0"
                          VerticalAlignment="Center" Visibility="Collapsed"
                          Checked="OnFilterChanged" Unchecked="OnFilterChanged"/>
                <Button x:Name="ClearBButton" Content="Clear B" Click="OnClearBClick"
                        Padding="6,3" Margin="12,0,0,0" Visibility="Collapsed"
                        Foreground="#FFCCCCCC" Background="#FF3E3E42" BorderBrush="#FF555555"/>
                <Button x:Name="ExportButton" Content="Export" Click="OnExportClick"
                        Padding="6,3" Margin="4,0,0,0" Visibility="Collapsed"
                        ToolTip="Copy XAML Style to clipboard"
                        Foreground="#FFCCCCCC" Background="#FF3E3E42" BorderBrush="#FF555555"/>
                <Button x:Name="ResetAllButton" Content="Reset All" Click="OnResetAllClick"
                        Padding="6,3" Margin="4,0,0,0" Visibility="Collapsed"
                        Foreground="#FFCCCCCC" Background="#FF3E3E42" BorderBrush="#FF555555"/>
            </StackPanel>
        </Border>

        <!-- Element A info -->
        <Border x:Name="ElementInfoPanel" Grid.Row="1" Background="#FF252526"
                BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1" Padding="8,4"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="A " Foreground="#FF9CDCFE" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="ElementType" FontSize="13" Foreground="#FF9CDCFE"/>
                </StackPanel>
                <TextBlock x:Name="ElementDetail" FontSize="11" Foreground="#FF666666" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Element B info -->
        <Border x:Name="ElementBInfoPanel" Grid.Row="2" Background="#FF252526"
                BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1" Padding="8,4"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="B " Foreground="#FFCE9178" FontWeight="Bold" FontSize="11"/>
                    <TextBlock x:Name="ElementBType" FontSize="13" Foreground="#FFCE9178"/>
                </StackPanel>
                <TextBlock x:Name="ElementBDetail" FontSize="11" Foreground="#FF666666" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Style chain -->
        <Border x:Name="StyleChainPanel" Grid.Row="3" Background="#FF252526"
                BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1" Padding="8,4"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Style Chain" Foreground="#FF9CDCFE" FontWeight="SemiBold" FontSize="11"/>
                    <Button x:Name="CopyChainButton" Content="Copy" Click="OnCopyChainClick"
                            Padding="4,0" Margin="8,0,0,0" FontSize="10"
                            Foreground="#FF888888" Background="Transparent" BorderThickness="0"/>
                </StackPanel>
                <ItemsControl x:Name="StyleChainList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <TextBlock Text="{Binding Label}" Foreground="#FFD4D4D4" FontSize="11"
                                           Cursor="Hand" MouseLeftButtonDown="OnStyleChainEntryClick"
                                           ToolTip="{Binding Detail}"/>
                                <TextBlock FontSize="11" Foreground="#FF666666" Margin="6,0,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="({0}s, {1}t)">
                                            <Binding Path="SetterCount"/>
                                            <Binding Path="TriggerCount"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding DictionarySource}" FontSize="10"
                                           Foreground="#FF608B4E" Margin="6,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DictionarySource}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Triggers -->
        <Border x:Name="TemplatePanel" Grid.Row="4" Background="#FF252526"
                BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1" Padding="8,4"
                Visibility="Collapsed">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="Triggers" Foreground="#FFC586C0" FontWeight="SemiBold" FontSize="11"/>
                    <TextBlock x:Name="TemplateTargetType" Foreground="#FFD4D4D4" FontSize="11" Margin="8,0,0,0"/>
                    <TextBlock x:Name="TemplateDictSource" Foreground="#FF608B4E" FontSize="10" Margin="6,0,0,0"/>
                </StackPanel>
                <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto"
                              Margin="0,2,0,0">
                    <ItemsControl x:Name="TemplateTriggerList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1">
                                    <TextBlock Text="{Binding ActiveIndicator}" FontSize="9"
                                               VerticalAlignment="Center" Width="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FF666666"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="#FF4EC9B0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Foreground" Value="#FF555555"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Source}" Foreground="#FF888888" FontSize="10"
                                               Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Condition}" Foreground="#FFD4D4D4" FontSize="11"
                                               Cursor="Hand" MouseLeftButtonDown="OnTemplateTriggerClick"
                                               ToolTip="{Binding SettersTooltip}"/>
                                    <TextBlock Text="{Binding SettersSummary}" FontSize="11"
                                               Foreground="#FF666666" Margin="6,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Main content: Visual Tree + Property List -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreeColumn" Width="0"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition x:Name="TreeBColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Visual tree panel -->
            <DockPanel x:Name="TreePanel" Grid.Column="0" Visibility="Collapsed">
                <Border DockPanel.Dock="Top" Background="#FF2D2D30" Padding="6,3"
                        BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="TreePanelLabel" Text="Visual Tree" Foreground="#FF9CDCFE"
                                   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                        <Button x:Name="TemplateTreeToggle" Click="OnTemplateTreeToggle"
                                Padding="3,1" Margin="8,0,0,0"
                                Background="#FF3E3E42" BorderBrush="#FF555555"
                                ToolTip="Toggle template tree view">
                            <TextBlock x:Name="TemplateTreeToggleText" Text="T"
                                       Foreground="#FFC586C0" FontSize="10" FontWeight="Bold"/>
                        </Button>
                        <Button x:Name="TreeUpButton" Click="OnTreeUpClick"
                                Padding="3,1" Margin="8,0,0,0"
                                Background="#FF3E3E42" BorderBrush="#FF555555"
                                ToolTip="Navigate up one level">
                            <TextBlock Text="↑" Foreground="#FFCCCCCC" FontSize="12"/>
                        </Button>
                        <Button x:Name="TreeExpandAllButton" Click="OnTreeExpandAllClick"
                                Padding="3,1" Margin="2,0,0,0"
                                Background="#FF3E3E42" BorderBrush="#FF555555"
                                ToolTip="Show full tree from root">
                            <TextBlock Text="⇈" Foreground="#FFCCCCCC" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Border>
                <TreeView x:Name="VisualTreeView" Background="#FF1E1E1E" BorderThickness="0"
                          SelectedItemChanged="OnTreeNodeSelected"
                          ItemContainerStyle="{StaticResource CompactTreeItemStyle}"
                          VirtualizingPanel.IsVirtualizing="False">
                    <TreeView.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF264F78"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF264F78"/>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Label}" ToolTip="{Binding TypeName}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter x:Name="TreeSplitter" Grid.Column="1" Width="4"
                          Background="#FF3F3F46" Visibility="Collapsed"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Property list -->
            <ListBox Grid.Column="2" x:Name="PropertyList"
                     Background="#FF1E1E1E" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Grid.IsSharedSizeScope="True"
                     VirtualizingPanel.IsVirtualizing="False">

                <ListBox.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="#FF2D2D30" Padding="8,3" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding Name}" Foreground="#FF9CDCFE"
                                               FontWeight="SemiBold" FontSize="11"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListBox.GroupStyle>
            </ListBox>

            <!-- Splitter B -->
            <GridSplitter x:Name="TreeBSplitter" Grid.Column="3" Width="4"
                          Background="#FF3F3F46" Visibility="Collapsed"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Visual tree B panel -->
            <DockPanel x:Name="TreeBPanel" Grid.Column="4" Visibility="Collapsed">
                <Border DockPanel.Dock="Top" Background="#FF2D2D30" Padding="6,3"
                        BorderBrush="#FF3F3F46" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tree B" Foreground="#FFCE9178"
                                   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                        <Button Click="OnTreeBUpClick"
                                Padding="3,1" Margin="8,0,0,0"
                                Background="#FF3E3E42" BorderBrush="#FF555555"
                                ToolTip="Navigate up one level">
                            <TextBlock Text="↑" Foreground="#FFCCCCCC" FontSize="12"/>
                        </Button>
                        <Button Click="OnTreeBExpandAllClick"
                                Padding="3,1" Margin="2,0,0,0"
                                Background="#FF3E3E42" BorderBrush="#FF555555"
                                ToolTip="Show full tree from root">
                            <TextBlock Text="⇈" Foreground="#FFCCCCCC" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Border>
                <TreeView x:Name="VisualTreeBView" Background="#FF1E1E1E" BorderThickness="0"
                          SelectedItemChanged="OnTreeBNodeSelected"
                          ItemContainerStyle="{StaticResource CompactTreeItemStyle}"
                          VirtualizingPanel.IsVirtualizing="False">
                    <TreeView.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF264F78"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF264F78"/>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Label}" ToolTip="{Binding TypeName}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="6" Background="#FF2D2D30" BorderBrush="#FF3F3F46" BorderThickness="0,1,0,0" Padding="8,3">
            <TextBlock x:Name="StatusText" Foreground="#FF888888" FontSize="11"
                       Text="Pick A to inspect, Pick B to compare"/>
        </Border>
    </Grid>
</Window>
