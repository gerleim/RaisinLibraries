<Window x:Class="StyleTestbed.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:controls="clr-namespace:Raisin.WPF.Base.Controls;assembly=Raisin.WPF.Base"
        Title="Style Testbed" Width="900" Height="700"
        Background="#1E1E1E">
    <Window.Resources>
        <x:Array x:Key="SampleItems" Type="sys:String">
            <sys:String>Alpha</sys:String>
            <sys:String>Bravo</sys:String>
            <sys:String>Charlie</sys:String>
            <sys:String>Delta</sys:String>
        </x:Array>
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,20,0,8"/>
        </Style>
        <Style x:Key="StateLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
        <StackPanel Margin="24,16">

            <TextBlock Text="Style Testbed" Foreground="#DDDDDD" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="SharedTheme.xaml control styles" Foreground="#888888" FontSize="12" Margin="0,0,0,16"/>

            <!-- FieldLabel -->
            <TextBlock Text="FieldLabel" Style="{StaticResource GroupHeader}"/>
            <TextBlock Text="This is a field label" Style="{StaticResource FieldLabel}"/>

            <!-- FieldBox -->
            <TextBlock Text="FieldBox (TextBox)" Style="{StaticResource GroupHeader}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Default" Style="{StaticResource StateLabel}"/>
                <TextBox Text="Editable text" Style="{StaticResource FieldBox}" Width="250"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Read-only" Style="{StaticResource StateLabel}"/>
                <TextBox Text="Read-only text" Style="{StaticResource FieldBox}" Width="250" IsReadOnly="True"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Disabled" Style="{StaticResource StateLabel}"/>
                <TextBox Text="Disabled text" Style="{StaticResource FieldBox}" Width="250" IsEnabled="False"/>
            </StackPanel>
            <TextBlock Text="Tab into these to see focus border (#569DE5):" Foreground="#666666" FontSize="10" Margin="0,4,0,4"/>
            <StackPanel Orientation="Horizontal">
                <TextBox Text="Field A" Style="{StaticResource FieldBox}" Width="150" Margin="0,0,8,0"/>
                <TextBox Text="Field B" Style="{StaticResource FieldBox}" Width="150" Margin="0,0,8,0"/>
                <TextBox Text="Field C" Style="{StaticResource FieldBox}" Width="150"/>
            </StackPanel>

            <!-- FieldCombo -->
            <TextBlock Text="FieldCombo (ComboBox)" Style="{StaticResource GroupHeader}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Default" Style="{StaticResource StateLabel}"/>
                <controls:FieldComboBox Style="{StaticResource FieldCombo}" Width="200"
                          ItemsSource="{StaticResource SampleItems}" SelectedIndex="0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Disabled" Style="{StaticResource StateLabel}"/>
                <controls:FieldComboBox Style="{StaticResource FieldCombo}" Width="200"
                          ItemsSource="{StaticResource SampleItems}" SelectedIndex="1" IsEnabled="False"/>
            </StackPanel>
            <TextBlock Text="Tab / click to test hover (#7EB4EA), focus (#569DE5), dropdown fade:" Foreground="#666666" FontSize="10" Margin="0,4,0,4"/>
            <StackPanel Orientation="Horizontal">
                <controls:FieldComboBox Style="{StaticResource FieldCombo}" Width="150" Margin="0,0,8,0"
                          ItemsSource="{StaticResource SampleItems}" SelectedIndex="0"/>
                <controls:FieldComboBox Style="{StaticResource FieldCombo}" Width="150"
                          ItemsSource="{StaticResource SampleItems}" SelectedIndex="2"/>
            </StackPanel>

            <!-- SmallButton -->
            <TextBlock Text="SmallButton" Style="{StaticResource GroupHeader}"/>
            <TextBlock Text="Hover (#454549 bg, #7EB4EA border)  |  Focus (#454549 bg, #569DE5 border)  |  Pressed (#505054 bg)" Foreground="#666666" FontSize="10" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Default" Style="{StaticResource StateLabel}"/>
                <Button Content="Change..." Style="{StaticResource SmallButton}" Margin="0,0,6,0"/>
                <Button Content="Set..." Style="{StaticResource SmallButton}" Margin="0,0,6,0"/>
                <Button Content="Clear" Style="{StaticResource SmallButton}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Disabled" Style="{StaticResource StateLabel}"/>
                <Button Content="Change..." Style="{StaticResource SmallButton}" IsEnabled="False" Margin="0,0,6,0"/>
                <Button Content="Clear" Style="{StaticResource SmallButton}" IsEnabled="False"/>
            </StackPanel>
            <TextBlock Text="Tab through to test keyboard focus:" Foreground="#666666" FontSize="10" Margin="0,4,0,4"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="First" Style="{StaticResource SmallButton}" Margin="0,0,6,0"/>
                <Button Content="Second" Style="{StaticResource SmallButton}" Margin="0,0,6,0"/>
                <Button Content="Third" Style="{StaticResource SmallButton}"/>
            </StackPanel>

            <!-- Form layout -->
            <TextBlock Text="Form Layout (DockPanel + TabIndex)" Style="{StaticResource GroupHeader}"/>
            <TextBlock Text="Tab order: TextBox -> action button -> Clear" Foreground="#666666" FontSize="10" Margin="0,0,0,6"/>
            <StackPanel>
                <TextBlock Text="Project" Style="{StaticResource FieldLabel}" Margin="0,0,0,3"/>
                <DockPanel KeyboardNavigation.TabNavigation="Local">
                    <Button Content="Clear" DockPanel.Dock="Right" Margin="6,0,0,0"
                            Style="{StaticResource SmallButton}" TabIndex="2"/>
                    <Button Content="Change..." DockPanel.Dock="Right" Margin="6,0,0,0"
                            Style="{StaticResource SmallButton}" TabIndex="1"/>
                    <TextBox Text="MyProject" Style="{StaticResource FieldBox}" IsReadOnly="True" TabIndex="0"/>
                </DockPanel>

                <TextBlock Text="Session" Style="{StaticResource FieldLabel}" Margin="0,12,0,3"/>
                <DockPanel KeyboardNavigation.TabNavigation="Local">
                    <Button Content="Clear" DockPanel.Dock="Right" Margin="6,0,0,0"
                            Style="{StaticResource SmallButton}" TabIndex="2"/>
                    <Button Content="Change..." DockPanel.Dock="Right" Margin="6,0,0,0"
                            Style="{StaticResource SmallButton}" TabIndex="1"/>
                    <TextBox Text="RT 1" Style="{StaticResource FieldBox}" IsReadOnly="True" TabIndex="0"/>
                </DockPanel>

                <TextBlock Text="Parent" Style="{StaticResource FieldLabel}" Margin="0,12,0,3"/>
                <DockPanel KeyboardNavigation.TabNavigation="Local">
                    <Button Content="Clear" DockPanel.Dock="Right" Margin="6,0,0,0"
                            Style="{StaticResource SmallButton}" TabIndex="2"/>
                    <Button Content="Set..." DockPanel.Dock="Right" Margin="6,0,0,0"
                            Style="{StaticResource SmallButton}" TabIndex="1"/>
                    <TextBox Text="(none)" Style="{StaticResource FieldBox}" IsReadOnly="True" TabIndex="0"/>
                </DockPanel>
            </StackPanel>

            <!-- FieldDropdown (multi-select, form style) -->
            <TextBlock Text="FieldDropdown (MultiSelectDropdown)" Style="{StaticResource GroupHeader}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Default" Style="{StaticResource StateLabel}"/>
                <controls:MultiSelectDropdown Style="{StaticResource FieldDropdown}" Width="200"
                    ItemsSource="{Binding SampleFilterItems}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Disabled" Style="{StaticResource StateLabel}"/>
                <controls:MultiSelectDropdown Style="{StaticResource FieldDropdown}" Width="200"
                    ItemsSource="{Binding SampleFilterItems}" IsEnabled="False"/>
            </StackPanel>
            <TextBlock Text="Sharp corners, #3F3F46 border — matches FieldCombo for detail forms:" Foreground="#666666" FontSize="10" Margin="0,4,0,4"/>
            <StackPanel Orientation="Horizontal">
                <controls:MultiSelectDropdown Style="{StaticResource FieldDropdown}" Width="150" Margin="0,0,8,0"
                    ItemsSource="{Binding SampleFilterItems}"/>
                <controls:MultiSelectDropdown Style="{StaticResource FieldDropdown}" Width="150"
                    ItemsSource="{Binding SampleFilterItems}"/>
            </StackPanel>

            <!-- FilterDropdown (multi-select, filter bar style) -->
            <TextBlock Text="FilterDropdown (MultiSelectDropdown)" Style="{StaticResource GroupHeader}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Default" Style="{StaticResource StateLabel}"/>
                <controls:MultiSelectDropdown Style="{StaticResource FilterDropdown}" Width="200"
                    ItemsSource="{Binding SampleFilterItems}"/>
            </StackPanel>
            <TextBlock Text="Rounded corners, #555555 border — for filter bars and toolbars:" Foreground="#666666" FontSize="10" Margin="0,4,0,4"/>
            <StackPanel Orientation="Horizontal">
                <controls:MultiSelectDropdown Style="{StaticResource FilterDropdown}" Width="120" Margin="0,0,8,0"
                    ItemsSource="{Binding SampleFilterItems}"/>
                <controls:MultiSelectDropdown Style="{StaticResource FilterDropdown}" Width="120" Margin="0,0,8,0"
                    ItemsSource="{Binding SampleFilterItems}"/>
                <controls:MultiSelectDropdown Style="{StaticResource FilterDropdown}" Width="120"
                    ItemsSource="{Binding SampleFilterItems}"/>
            </StackPanel>

            <!-- FilterComboBox -->
            <TextBlock Text="FilterComboBox (MD-based, single-select)" Style="{StaticResource GroupHeader}"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Default" Style="{StaticResource StateLabel}"/>
                <ComboBox Style="{StaticResource FilterComboBox}" Width="120"
                          ItemsSource="{StaticResource SampleItems}" SelectedIndex="0"/>
            </StackPanel>

            <!-- Side by side -->
            <TextBlock Text="Side-by-Side: Form vs Filter" Style="{StaticResource GroupHeader}"/>
            <TextBlock Text="Form controls (sharp corners, #3F3F46 border) vs filter variants (rounded, #555555 border)" Foreground="#666666" FontSize="10" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#333333" BorderThickness="1" Padding="16,12" Background="#252526">
                    <StackPanel>
                        <TextBlock Text="FORM STYLE" Foreground="#569DE5" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Single-select" Style="{StaticResource FieldLabel}"/>
                        <controls:FieldComboBox Style="{StaticResource FieldCombo}"
                                  ItemsSource="{StaticResource SampleItems}" SelectedIndex="0" Margin="0,0,0,8"/>
                        <TextBlock Text="Multi-select" Style="{StaticResource FieldLabel}"/>
                        <controls:MultiSelectDropdown Style="{StaticResource FieldDropdown}" Margin="0,0,0,8"
                            ItemsSource="{Binding SampleFilterItems}"/>
                        <TextBlock Text="Text field" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="Form field" Style="{StaticResource FieldBox}" Margin="0,0,0,8"/>
                        <Button Content="Action" Style="{StaticResource SmallButton}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" BorderBrush="#333333" BorderThickness="1" Padding="16,12" Background="#252526">
                    <StackPanel>
                        <TextBlock Text="FILTER STYLE" Foreground="#569DE5" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Single-select (MD)" Style="{StaticResource FieldLabel}"/>
                        <ComboBox Style="{StaticResource FilterComboBox}" Margin="0,0,0,8"
                                  ItemsSource="{StaticResource SampleItems}" SelectedIndex="0"/>
                        <TextBlock Text="Multi-select" Style="{StaticResource FieldLabel}"/>
                        <controls:MultiSelectDropdown Style="{StaticResource FilterDropdown}" Margin="0,0,0,8"
                            ItemsSource="{Binding SampleFilterItems}"/>
                        <TextBlock Text="Text field" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="Filter text" Style="{StaticResource FilterBox}" Margin="0,0,0,8"/>
                        <Button Content="Action" Style="{StaticResource FilterButton}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Height="24"/>
        </StackPanel>
    </ScrollViewer>
</Window>
